{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/wf",
      "destination": "/wf/",
      "permanent": true
    },
    {
      "source": "/world-flipper",
      "destination": "/wf/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/wf/(.*)\\.(js|png|jpg|jpeg|webp|gif|svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/wf/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
